#!/usr/bin/env bash

# CuriOS update script as NixOS package.
#
# Usage:
#       curios-update [options]
# Options:
#     -h, --help         Print this message.
#     --check            Check online if a most recent version of CuriOS exist.
#     --upgrade          Download latest CuriOS and install it. Implies --check option.
#     -v, --verbose      Print more information.
#     --version          Print version number and exit.
#
# Examples:
#    Check online for the latest version:
#      curios-update --check
#    Upgrade system:
#      curios-update --upgrade

set -eu

readonly SCRIPT_VERSION="0.18"
readonly CURIOS_MODULES_FILE="/etc/nixos/modules.json"
#------------- Colors -------------#
readonly RED="\033[31;1m"      # Red and bold
readonly GREEN="\033[32;1m"    # Green and bold
readonly BLUE="\033[34;1m"     # Blue and bold
readonly GREY="\033[37;1m"     # Grey and bold
readonly YELLOW="\033[33;1;3m" # Yellow, bold and italic
readonly NC="\033[0m"          # No Color

#------------- Trap for cleanup
TMP_DIR=$(mktemp -d -t curios-update-XXXXXX)
trap 'rm -rf -- "$TMP_DIR"' EXIT

#------------- Print help function
usage() {
  echo -e "CuriOS system manager version ${SCRIPT_VERSION}
  * A script for managing your CuriOS system from the command line *

${GREY}USAGE:${NC}
  curios-update [options]

${GREY}OPTIONS:${NC}
  ${GREY}-h, --help${NC}                  Print this message.
  ${GREY}--check${NC}                     Check online if a most recent version of CuriOS exist.
  ${GREY}--export${NC}                    Export current CuriOS modules configuration to '$CURIOS_MODULES_FILE'.
  ${GREY}--show-modules${NC}              Show all CuriOS module settings stored in '$CURIOS_MODULES_FILE'. JSON output.
  ${GREY}--search-modules KEY${NC}        Search for a CuriOS module setting key by name in '$CURIOS_MODULES_FILE'. JSON output.
  ${GREY}--nixos-option OPTION${NC}       Query the current value of any NixOS option or CuriOS module.
  ${GREY}--update-module KEY VALUE${NC}  Change a CuriOS module setting (updates '$CURIOS_MODULES_FILE').
  ${GREY}--update${NC}                    Update system, installed packages, Nix flakes, do a Nix collect garbage and warn user if a reboot is necessary.
  ${GREY}--upgrade${NC}                   Download latest CuriOS system and install it. Implies --check option.
  ${GREY}--search-pkgs PKG_NAME${NC}      Search for a package in NixOS channel using its name. JSON output, use 'package_attr_name' key value for --add-pkg option.
  ${GREY}--add-pkg PKG_NAME${NC}          Add a NixOS package into '/etc/nixos/settings.nix', and update the system (--update is implied).
  ${GREY}-v, --verbose${NC}               Print more information.
  ${GREY}--version${NC}                   Print version number and exit.

${GREY}EXAMPLES:${NC}
  Check online for the latest CuriOS version:
    ${GREY}curios-update --check${NC}
  If check says so, upgrade whole system to latest version:
    ${GREY}sudo curios-update --upgrade${NC}
  Export CuriOS current modules configuration:
    ${GREY}sudo curios-update --export${NC}

  Update a CuriOS module sequence for installing firefox and set system time-zone:
  Show CuriOS current configuration for all modules:
    ${GREY}curios-update --show-modules${NC}
  Search for a CuriOS module by name (i.e: firefox):
    ${GREY}curios-update --search-modules firefox${NC}
  Check a NixOS or CuriOS configuration details:
    ${GREY}curios-update --nixos-option curios.system.timeZone${NC}
  Then update a CuriOS module configuration:
    ${GREY}sudo curios-update --update-module curios.desktop.browser.firefox.enable true${NC}
    ${GREY}sudo curios-update --update-module curios.system.timeZone \"Europe/Berlin\"${NC}
  Finally, it MUST be followed by a system update:
    ${GREY}sudo curios-update --update${NC}

  Search for a NixOS package by name:
    ${GREY}curios-update --search-pkgs blender${NC}
  Then install the previously found package:
    ${GREY}sudo curios-update --add-pkg blender${NC}
"
  exit 0
}

#------------- var init state
VERBOSE=0
CHECK_ONLINE=0
EXPORT_MODULES=0
SHOW_MODULES=0
SEARCH_MODULES=0
RUN_NIXOS_OPTION=0
UPDATE_MODULES=0
UPDATE_SYSTEM=0
SEARCH_PKGS=0
ADD_PKG=0
UPGRADE_SYSTEM=0
UPGRADABLE=0
LATEST_VERSION=""
LATEST_SOURCE=""
NIX_CHANNEL_URL=""
UPDATE_KEY=""
UPDATE_VALUE=""
NIXOS_OPTION_PATH=""
SEARCH_PKG_NAME=""
SEARCH_MODULE_KEY=""
ADD_PKG_NAME=""
SCRIPT_PATH="$(dirname "$0")"

#------------- Scripts arguments parse options
ARGS=$(getopt --longoptions="verbose,version,help,check,export,show-modules,search-modules:,nixos-option:,search-pkgs:,add-pkg:,update-module:,update,upgrade" --options ":hvs" -- "$@")
if [ $# -eq 0 ]; then
  usage
fi

eval set -- "$ARGS"

while true; do
  case "$1" in
  -v | --verbose)
    VERBOSE=1
    shift
    ;;
  -h | --help)
    usage
    ;;
  -s | --show-modules)
    SHOW_MODULES=1
    shift
    ;;
  --search-modules)
    SEARCH_MODULES=1
    SEARCH_MODULE_KEY="$2"
    shift 2
    ;;
  --nixos-option)
    RUN_NIXOS_OPTION=1
    NIXOS_OPTION_PATH="$2"
    shift 2
    ;;
  --search-pkgs)
    SEARCH_PKGS=1
    SEARCH_PKG_NAME="$2"
    shift 2
    ;;
  --add-pkg)
    ADD_PKG=1
    ADD_PKG_NAME="$2"
    shift 2
    ;;
  --check)
    CHECK_ONLINE=1
    shift
    ;;
  --export)
    EXPORT_MODULES=1
    shift
    ;;
  --update-module)
    UPDATE_MODULES=1
    UPDATE_KEY="$2"
    shift 2
    ;;
  --update)
    UPDATE_SYSTEM=1
    shift
    ;;
  --upgrade)
    UPGRADE_SYSTEM=1
    CHECK_ONLINE=1
    shift
    ;;
  --version)
    echo "$SCRIPT_VERSION"
    exit 0
    ;;
  --)
    shift
    break
    ;;
  *)
    break
    ;;
  esac
done

if [ $VERBOSE -eq 1 ]; then
  echo "Script current path: ${SCRIPT_PATH}"
  echo "PATH: $PATH"
fi

# This script must be run as root for --upgrade, --update, --export, --add-pkg and --update-module option
if [[ "$EUID" -ne 0 ]] && [[ $UPGRADE_SYSTEM -eq 1 || $UPDATE_SYSTEM -eq 1 || $EXPORT_MODULES -eq 1 || $ADD_PKG -eq 1 || $UPDATE_MODULES -eq 1 ]]; then
  echo -e "${RED}This script MUST be run as root: sudo curios-update --add-pkg PKG_NAME${NC}" >&2
  exit 1
fi

# Check dependencies
available() { command -v "$1" >/dev/null; }

if ! available notify-send; then
  echo -e "${RED}notify-send command not found!${NC}"
  exit 1
fi
if ! available wget; then
  echo -e "${RED}wget command not found!${NC}"
  exit 1
fi
if ! available curl; then
  echo -e "${RED}curl command not found!${NC}"
  exit 1
fi
if ! available jq; then
  echo -e "${RED}jq command not found!${NC}"
  exit 1
fi
if ! available tar; then
  echo -e "${RED}tar command not found!${NC}"
  exit 1
fi
if ! available fd; then
  echo -e "${RED}fd command not found!${NC}"
  exit 1
fi
if ! available nixos-option; then
  echo -e "${RED}nixos-option command not found!${NC}"
  exit 1
fi
#if ! available nix-instantiate; then
#  echo -e "${RED}nix-instantiate command not found!${NC}"
#  exit 1
#fi

# check online latest version
get_latest_version() {
  if [ $VERBOSE -eq 1 ]; then
    echo -e "${BLUE}Checking github sources...${NC}"
  fi
  local LATEST_INFO
  LATEST_INFO=$(curl -f -L --silent "https://api.github.com/repos/CuriosLabs/CuriOS/tags" | jq -r '.[0]')
  LATEST_VERSION=$(echo "$LATEST_INFO" | jq -r '.name')
  LATEST_SOURCE=$(echo "$LATEST_INFO" | jq -r '.tarball_url')
}

# Update Nix packages, system, collect garbage
update_curios() {
  echo -e "${GREEN}Launching Nix garbage collection...${NC}"
  nix-collect-garbage --delete-older-than 7d >/dev/null
  echo -e "${GREEN}Updating CuriOS system...${NC}"
  nixos-rebuild switch --upgrade --cores 0 --max-jobs auto >/dev/null
  echo -e "${GREEN}Updating Nix flakes...${NC}"
  nix profile upgrade --all >/dev/null
  reboot_check
}

# Check if current kernel and nix latest kernel generation are different
# If yes send the user a notification to reboot.
reboot_check() {
  LIST_GEN=$(nixos-rebuild list-generations --json)
  LIST_GEN_KERNEL=$(echo "$LIST_GEN" | jq -r '.[0].kernelVersion')
  if [[ $(uname -r) != "$LIST_GEN_KERNEL" ]]; then
    echo -e "A new kernel was installed - ${YELLOW}You should REBOOT now${NC}."
    # Send a notification to user with UID 1000
    sudo -u "#1000" DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus notify-send -a "System Update" --icon="curios" --urgency=critical --expire-time=8000 "A new kernel was installed - You SHOULD reboot now!"
  fi
}

# Export all NixOS options values from 'curios' to a JSON file
export_curios_modules() {
  echo -e "${GREEN}Exporting CuriOS modules to $CURIOS_MODULES_FILE${NC}"
  # Get all curios options, filter out errors and derivations
  # then wrap in a nix attribute set and convert to JSON using nix-instantiate
  if ! nixos-option -r curios >/dev/null 2>&1; then
    echo -e "${YELLOW}Warning: 'curios' option set not found. Skipping export.${NC}"
    return
  fi

  # Backup existing file if it exists
  if [ -f $CURIOS_MODULES_FILE ]; then
    local backup_file
    backup_file="$CURIOS_MODULES_FILE.$(date +%Y%m%d_%H%M%S).bak"
    cp $CURIOS_MODULES_FILE "$backup_file"
    echo -e "${BLUE}Backup created: ${backup_file}${NC}"
  fi

  local curios_current_options=""
  curios_current_options=$(nixos-option -r curios 2>/dev/null)
  echo "{$curios_current_options}" | /run/current-system/sw/bin/nix-instantiate --eval --strict --json - >$CURIOS_MODULES_FILE ||
    echo -e "${RED}Error: Failed to export CuriOS modules to JSON.${NC}"
}

# Print current CuriOS modules configuration
show_curios_modules() {
  if [ ! -f "$CURIOS_MODULES_FILE" ]; then
    echo -e "${YELLOW}Warning: $CURIOS_MODULES_FILE not found. Try --export first.${NC}"
    return
  fi
  jq '.' "$CURIOS_MODULES_FILE"
}

# Search for a CuriOS module key
search_curios_modules() {
  local key="$1"
  if [ ! -f "$CURIOS_MODULES_FILE" ]; then
    echo -e "${YELLOW}Warning: $CURIOS_MODULES_FILE not found. Try --export first.${NC}"
    return
  fi
  jq "[paths | select(any(.[]; tostring | contains(\"$key\"))) | join(\".\")]" "$CURIOS_MODULES_FILE"
}

# Add a package to /etc/nixos/settings.nix and install it
add_package_to_settings() {
  local PKG="$1"
  local SETTINGS_FILE="/etc/nixos/settings.nix"

  if [ -z "$PKG" ]; then
    echo -e "${RED}Error: Package name is empty.${NC}"
    exit 1
  fi

  # Check if package is already in the list
  if grep -q "pkgs.$PKG" "$SETTINGS_FILE"; then
    echo -e "${YELLOW}Package pkgs.$PKG is already present in $SETTINGS_FILE.${NC}"
    return
  fi

  # Add the package to the environment.systemPackages list.
  if sed -i "/environment.systemPackages = \[/a \    pkgs.$PKG" "$SETTINGS_FILE"; then
    echo -e "${GREEN}Package pkgs.$PKG added to $SETTINGS_FILE${NC}"
    update_curios
  else
    echo -e "${RED}Failed to add package pkgs.$PKG to $SETTINGS_FILE.${NC}"
    exit 1
  fi
}

# Update a value into the JSON file $CURIOS_MODULES_FILE
update_curios_modules() {
  local key="$1"
  local value="$2"
  local tmp_json
  tmp_json=$(mktemp /tmp/curios-modules-XXXXXX.json)

  if [ ! -f "$CURIOS_MODULES_FILE" ]; then
    echo -e "${RED}Error: $CURIOS_MODULES_FILE not found.${NC}"
    exit 1
  fi

  # Check if key exists
  if [[ $(jq -r ".$key" "$CURIOS_MODULES_FILE" 2>/dev/null) == "null" ]]; then
    echo -e "${RED}Error: Key '$key' not found in $CURIOS_MODULES_FILE${NC}"
    exit 1
  fi

  # Handle boolean vs string
  if [[ "$value" == "true" || "$value" == "false" ]]; then
    jq ".$key = $value" "$CURIOS_MODULES_FILE" >"$tmp_json"
  else
    jq --arg val "$value" ".$key = \$val" "$CURIOS_MODULES_FILE" >"$tmp_json"
  fi

  mv "$tmp_json" "$CURIOS_MODULES_FILE"
  chmod 644 "$CURIOS_MODULES_FILE"
  echo -e "${GREEN}Module configuration updated: $key = $value${NC}"
}

# Upgrade the system
upgrade_curios() {
  local extracted_source_path=""

  echo -e "${GREEN}Launching Nix garbage collector...${NC}"
  nix-store --gc

  echo -e "${GREEN}Downloading ${LATEST_VERSION} sources...${NC}"
  wget -O "${TMP_DIR}/CuriOS-${LATEST_VERSION}".tar.gz --show-progress "$LATEST_SOURCE"
  mkdir -p "${TMP_DIR}/CuriOS-${LATEST_VERSION}"/ && tar -C "${TMP_DIR}/CuriOS-${LATEST_VERSION}"/ -xzf "${TMP_DIR}/CuriOS-${LATEST_VERSION}".tar.gz
  extracted_source_path=$(fd . "${TMP_DIR}/CuriOS-${LATEST_VERSION}"/ --max-depth 1 --type d | head -n 1)
  echo "Sources extracted to ${extracted_source_path}"
  # Checking extracted source
  if [ ! -f "$extracted_source_path"/configuration.nix ]; then
    echo -e "${RED}configuration.nix file not found!${NC}"
    exit 1
  fi

  # Installing
  echo -e "${GREEN}Installing update...${NC}"
  install -D -m 644 -t /etc/nixos/ "$extracted_source_path"/configuration.nix
  if [ ! -f /etc/nixos/settings.nix ]; then
    install -D -m 644 -t /etc/nixos/ "$extracted_source_path"/settings.nix
    echo -e "${YELLOW}Default settings.nix file installed!${NC} EDIT /etc/nixos/settings.nix to match your username."
  fi
  if [ ! -f "$extracted_source_path"/logo.txt ]; then
    install -D -m 644 -t /etc/nixos/ "$extracted_source_path"/logo.txt
  fi
  #install -D -m 555 -t /etc/nixos/ "$extracted_source_path"/curios-*
  mkdir -p /etc/nixos/modules/
  cp -r -f "$extracted_source_path"/modules/ /etc/nixos/
  mkdir -p /etc/nixos/pkgs/
  cp -r -f "$extracted_source_path"/pkgs/ /etc/nixos/
  # Updating NixOS channel if necessary
  NIX_CHANNEL_URL=$(grep -oP -m 1 'channel\s*=\s*"\K[^"]+' /etc/nixos/configuration.nix)
  if [ -z "$NIX_CHANNEL_URL" ]; then
    echo -e "${RED}Nix channel not found in configuration.nix!${NC}"
    exit 1
  fi
  if nix-channel --list | grep -q "$NIX_CHANNEL_URL"; then
    echo -e "${BLUE}Nix channel is already up-to-date.${NC}"
  else
    echo -e "${YELLOW}Updating Nix channel...${NC}"
    nix-channel --add "$NIX_CHANNEL_URL" nixos
    nix-channel --update
  fi
  # Updating system
  echo -e "${YELLOW}Updating packages...${NC}"
  # Updating $CURIOS_MODULES_FILE
  export_curios_modules
  # Updating whole system
  nixos-rebuild switch --upgrade --cores 0 --max-jobs auto
  echo -e "${GREEN}Done.${NC}"
}

# Get current OS version
if [ ! -f /etc/os-release ]; then
  echo -e "${RED}/etc/os-release file not found!${NC}"
  exit 1
fi
source /etc/os-release
#echo -e "CuriOS current version is ${GREY}${VARIANT_ID}${NC}"

if [ $CHECK_ONLINE -eq 1 ]; then
  get_latest_version
  echo -e "CuriOS latest version is ${GREY}${LATEST_VERSION}${NC}"
  if [ "$LATEST_VERSION" == "$VARIANT_ID" ]; then
    echo -e "${GREEN}System is up-to-date.${NC}"
    exit 0
  else
    if [[ "$LATEST_VERSION" == [0-9][0-9]* ]]; then
      UPGRADABLE=1
      echo -e "${YELLOW}System should be upgraded.${NC}"
      if [ "$EUID" -ge 900 ]; then
        notify-send -a "CuriOS Updater" --urgency=critical "CuriOS ${LATEST_VERSION} is available!" "Launch Curios Manager with Super+Return (+󰌑) >  Upgrade OR in a terminal type: curios-manager"
      fi
    else
      UPGRADABLE=0
      echo -e "${YELLOW}Latest version number is not correct.${NC}"
    fi
  fi
fi

if [ $UPDATE_SYSTEM -eq 1 ]; then
  update_curios
  exit 0
fi

if [ $EXPORT_MODULES -eq 1 ]; then
  export_curios_modules
  exit 0
fi

if [ $SHOW_MODULES -eq 1 ]; then
  show_curios_modules
  exit 0
fi

if [ $SEARCH_MODULES -eq 1 ]; then
  if [ -z "$SEARCH_MODULE_KEY" ]; then
    echo -e "${RED}Error: --search-modules requires 1 argument: KEY${NC}"
    exit 1
  fi
  search_curios_modules "$SEARCH_MODULE_KEY"
  exit 0
fi

if [ $RUN_NIXOS_OPTION -eq 1 ]; then
  if [ -z "$NIXOS_OPTION_PATH" ]; then
    echo -e "${RED}Error: --nixos-option requires 1 argument: OPTION_PATH${NC}"
    exit 1
  fi
  nixos-option "$NIXOS_OPTION_PATH"
  exit 0
fi

if [ "$SEARCH_PKGS" -eq 1 ]; then
  if [ -z "$SEARCH_PKG_NAME" ]; then
    echo -e "${RED}Error: --search-pkgs requires 1 argument: PKG_NAME${NC}"
    exit 1
  fi
  nix-search --channel "$VERSION_ID" --json "$SEARCH_PKG_NAME"
  exit 0
fi

if [ "$ADD_PKG" -eq 1 ]; then
  add_package_to_settings "$ADD_PKG_NAME"
  exit 0
fi

if [ $UPDATE_MODULES -eq 1 ]; then
  if [ $# -lt 1 ]; then
    echo -e "${RED}Error: --update-module requires 2 arguments: KEY and VALUE${NC}"
    exit 1
  fi
  UPDATE_VALUE="$1"
  update_curios_modules "$UPDATE_KEY" "$UPDATE_VALUE"
  exit 0
fi

if [ $UPGRADABLE -eq 1 ] && [ $UPGRADE_SYSTEM -eq 1 ]; then
  upgrade_curios
  exit 2
fi

  exit 2
fi
